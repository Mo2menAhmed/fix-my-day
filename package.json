{
  "name": "fix-my-day",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "docker": "expo start --web --host lan --port 8081",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "login:expo": "npx --yes eas-cli@19.1.0 login --no-browser",
    "whoami:expo": "npx --yes eas-cli@19.1.0 whoami",
    "build:android": "npx --yes eas-cli@19.1.0 build --platform android --profile production",
    "build:android:aab": "npx --yes eas-cli@19.1.0 build --platform android --profile production",
    "build:android:apk:local": "npx --yes eas-cli@19.1.0 build --platform android --profile preview --local",
    "build:android:aab:local": "npx --yes eas-cli@19.1.0 build --platform android --profile production --local",
    "build:ios": "npx --yes eas-cli@19.1.0 build --platform ios --profile production",
    "build:all": "npx --yes eas-cli@19.1.0 build --platform all --profile production",
    "build:android:apk": "npx --yes eas-cli@19.1.0 build --platform android --profile preview",
    "build:preview:android": "npx --yes eas-cli@19.1.0 build --platform android --profile preview",
    "build:preview:ios": "npx --yes eas-cli@19.1.0 build --platform ios --profile preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "expo": "~56.0.5",
    "expo-splash-screen": "~56.0.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.15",
    "typescript": "~6.0.3"
  }
}

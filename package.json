{
  "name": "fix-my-day",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "docker": "expo start --web --host lan --port 8081",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "login:expo": "eas login --no-browser",
    "whoami:expo": "eas whoami",
    "build:android": "eas build --platform android --profile production",
    "build:android:apk:local": "eas build --platform android --profile preview --local",
    "build:android:aab:local": "eas build --platform android --profile production --local",
    "build:ios": "eas build --platform ios --profile production",
    "build:all": "eas build --platform all --profile production",
    "build:android:apk": "eas build --platform android --profile preview",
    "build:preview:android": "eas build --platform android --profile preview",
    "build:preview:ios": "eas build --platform ios --profile preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.1.0",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "expo": "~56.0.5",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.15",
    "eas-cli": "^19.1.0",
    "typescript": "~5.9.2"
  }
}
